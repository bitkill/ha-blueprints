# Copy this to `.env` and fill in your values.
# `.env` is gitignored — never commit real credentials.

# Home Assistant base URL (http(s)://). The tools derive the WebSocket
# URL by swapping the scheme to ws(s):// automatically.
HA_URL=http://homeassistant.local:8123

# Long-lived access token.
# Create one at: Profile → Security → "Create Token" (bottom of page).
HA_TOKEN=eyJhbGciOi...

# Default blueprint namespace for push_blueprint.py (the folder under
# /config/blueprints/automation/<namespace>/). Used if --namespace is
# not passed on the command line.
BLUEPRINT_NAMESPACE=bitkill

# Optional: if set, push_blueprint.py stamps uploaded blueprints with
# `source_url: {BLUEPRINT_SOURCE_BASE}/<filename>`. Useful if you mirror
# the repo to GitHub so HA's UI shows the source link.
BLUEPRINT_SOURCE_BASE=https://raw.githubusercontent.com/bitkill/ha-blueprints/refs/heads/main
